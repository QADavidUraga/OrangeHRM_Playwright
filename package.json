{
  "name": "playwright-orangehrm",
  "version": "2.0.0",
  "description": "Automatización de OrangeHRM y del chatbot MAZSalud con Playwright + TypeScript (Page Object Model)",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:orangehrm": "playwright test orangehrm.spec.ts",
    "test:chatbot": "playwright test chatbot.spec.ts",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
